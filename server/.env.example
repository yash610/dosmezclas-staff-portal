# ── Database ──────────────────────────────────────────────────────────────────
# Production (Vercel + Neon/Supabase PostgreSQL)
DB_CLIENT=pg
DATABASE_URL=postgres://user:password@host:5432/dosmezclas

# Local dev — comment out the two lines above and use these instead:
# DB_CLIENT=sqlite
# SQLITE_PATH=./dosmezclas.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change to a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=dosmezclas-dev-secret-change-me

# ── Registration ──────────────────────────────────────────────────────────────
# Anyone with this code can create a manager (admin) account.
# Keep it secret — share only with the restaurant owner/manager.
ADMIN_REGISTRATION_CODE=your-secret-manager-code

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated frontend origins allowed to call this API.
# Example: https://dosmezclas.vercel.app
CORS_ORIGIN=https://your-frontend.vercel.app

# ── Local dev only ────────────────────────────────────────────────────────────
PORT=4000
